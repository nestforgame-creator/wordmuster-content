{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "dataVersion",
    "generatedOn",
    "rows"
  ],
  "properties": {
    "dataVersion": {
      "type": "string"
    },
    "generatedOn": {
      "type": "string",
      "format": "date-time"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chapterId",
          "targetWordsCsv",
          "bonusWordsCsv"
        ],
        "properties": {
          "chapterId": {
            "type": "string"
          },
          "targetWordsCsv": {
            "type": "string"
          },
          "bonusWordsCsv": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
