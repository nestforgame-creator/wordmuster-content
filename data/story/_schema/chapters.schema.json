{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "dataVersion",
    "generatedOn",
    "chapters"
  ],
  "properties": {
    "dataVersion": {
      "type": "string"
    },
    "generatedOn": {
      "type": "string",
      "format": "date-time"
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chapterId",
          "storyId",
          "chapterNumber",
          "rackLetters",
          "displayOrder",
          "isActive"
        ],
        "properties": {
          "chapterId": {
            "type": "string"
          },
          "storyId": {
            "type": "string"
          },
          "chapterNumber": {
            "type": "integer"
          },
          "rackLetters": {
            "type": "string"
          },
          "displayOrder": {
            "type": "integer"
          },
          "isUnlockedByDefault": {
            "type": "boolean"
          },
          "starsToUnlock": {
            "type": "integer"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
