{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "dataVersion",
    "generatedOn",
    "sourceLexiconVersion",
    "collections"
  ],
  "properties": {
    "dataVersion": {
      "type": "string"
    },
    "generatedOn": {
      "type": "string",
      "format": "date-time"
    },
    "sourceLexiconVersion": {
      "type": "string"
    },
    "collections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "collectionCode",
          "title",
          "language",
          "displayOrder",
          "isActive"
        ],
        "properties": {
          "collectionCode": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "iconKey": {
            "type": "string"
          },
          "isUnlockedByDefault": {
            "type": "boolean"
          },
          "minChaptersToUnlock": {
            "type": "integer"
          },
          "ageBand": {
            "type": "string"
          },
          "difficultyBand": {
            "type": "string"
          },
          "coverImageUrl": {
            "type": "string"
          },
          "displayOrder": {
            "type": "integer"
          },
          "isActive": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
