{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "dataVersion",
    "generatedOn",
    "settings"
  ],
  "properties": {
    "dataVersion": {
      "type": "string"
    },
    "generatedOn": {
      "type": "string",
      "format": "date-time"
    },
    "settings": {
      "type": "object",
      "required": [
        "defaultRackSize",
        "maxBonusWords",
        "targetWordsPerChapter"
      ],
      "properties": {
        "defaultRackSize": {
          "type": "integer"
        },
        "maxBonusWords": {
          "type": "integer"
        },
        "targetWordsPerChapter": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
